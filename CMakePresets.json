{
  "version": 3,
  "configurePresets": [
    {
      "name": "mingw-release",
      "displayName": "MinGW Release (x64-mingw-dynamic)",
      "description": "使用 MinGW GCC + Ninja 构建 Release 版本。请先设置 VCPKG_ROOT 环境变量指向 vcpkg 安装目录。",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/mingw-Release",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "g++",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      },
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "mingw-debug",
      "displayName": "MinGW Debug (x64-mingw-dynamic)",
      "description": "使用 MinGW GCC + Ninja 构建 Debug 版本",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/mingw-Debug",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "g++",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      },
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "msvc-release",
      "displayName": "MSVC Release (x64-windows)",
      "description": "使用 MSVC + Ninja 构建 Release 版本",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/msvc-Release",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "msvc-debug",
      "displayName": "MSVC Debug (x64-windows)",
      "description": "使用 MSVC + Ninja 构建 Debug 版本",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/msvc-Debug",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "mingw-release",
      "configurePreset": "mingw-release",
      "configuration": "Release"
    },
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug",
      "configuration": "Debug"
    },
    {
      "name": "msvc-release",
      "configurePreset": "msvc-release",
      "configuration": "Release"
    },
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug",
      "configuration": "Debug"
    }
  ]
}
